# Copy this file to .env.local and fill in the values

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Random 32+ char secret for signing session cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret-string"

# Used by prisma/seed.ts to create the initial admin account
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Vercel Blob token for admin image uploads (public/uploads is read-only on Vercel).
# Auto-added to the project when you create a Blob store in the Vercel dashboard;
# for local dev run `vercel env pull .env.local` or paste the token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"