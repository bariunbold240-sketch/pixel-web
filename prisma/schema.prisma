generator client {
  provider = "prisma-client-js"
}

// In Prisma 7 the connection URL is configured in prisma.config.ts (not here).
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-managed projects (WorkSection / Төслүүд)
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  status      String   @default("Идэвхтэй")
  members     Int      @default(0)
  color       String   @default("#6f63ff")
  image       String   @default("")
  description String   @default("")
  stats       Json     @default("[]") // { value: string; label: string }[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Admin-managed packages (05 / Багц section)
model Package {
  id        Int      @id @default(autoincrement())
  name      String
  price     String   @default("")
  featured  Boolean  @default(false)
  features  Json     // { label: string; value: string }[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 03 / Харилцаа section — gallery photos
model GalleryPhoto {
  id        Int      @id @default(autoincrement())
  src       String   // e.g. "/photo_2026-06-26_12-48-06.jpg"
  alt       String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Бүтээгдэхүүн section — tech strip icons
model TechIcon {
  id        Int      @id @default(autoincrement())
  src       String   // e.g. "/icon/icon1.png"
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Баг section — онцлох YouTube бичлэгүүд
model Video {
  id        Int      @id @default(autoincrement())
  youtubeId String   // 11-тэмдэгт id, ямар ч хэлбэрийн YouTube линкээс задлагдана
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
